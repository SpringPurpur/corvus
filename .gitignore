# Models — trained externally, not stored in git
inference/models/*.pkl
inference/models/*.joblib

# Dashboard build output — regenerated, not stored
dashboard/dist/
dashboard/node_modules/

# Docker / runtime
.docker/
*.sock

# SQLite flow database — written at runtime, not stored in git
data/

# Scenario results — generated at runtime, not stored in git
scenarios/old/
scenarios/results/

# IDE
.vscode/settings.json
.idea/
*.swp