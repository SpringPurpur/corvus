# .env.example - copy to .env and fill in values.
# Never commit .env to version control.

# LLM integration
# Anthropic API key for alert explanation, feedback parsing, and analyst chat.
# Leave empty to run without LLM features (the rest of the IDS still works).
ANTHROPIC_API_KEY=

# Dashboard authentication
# When set, every API call must carry X-API-Key: <value>.
# The WebSocket uses ?key=<value> instead (browsers can't set WS headers).
# The dashboard prompts for this key on first load if it isn't in sessionStorage.
# Leave empty to disable authentication (local / trusted-network deployments).
CORVUS_API_KEY=

# Capture interface
# Explicit interface for the capture engine. If unset, the engine tries:
#   1. Any UP+PROMISC interface (set with: ip link set <iface> promisc on)
#   2. The Docker bridge for 172.20.0.0/24 (testbed auto-detect)
# Examples: eth0, ens3, bond0, enp3s0
CAPTURE_INTERFACE=

# Optional BPF pre-filter applied before flow assembly.
# Reduces CPU load by dropping traffic you don't want to inspect.
# Example: ip and not host 10.0.0.1
CAPTURE_FILTER=

# Port
# Host port the inference engine (dashboard + API + WebSocket) listens on.
# Default: 8765
CORVUS_PORT=8765
